{
  "name": "manje-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npm run network:fix && expo start --go",
    "start:go": "npm run network:fix && expo start --go",
    "start:go:8081": "npm run network:fix && expo start --go --port 8081",
    "start:go:8082": "npm run network:fix && expo start --go --port 8082",
    "start:go:offline": "npm run network:fix && expo start --go --offline",
    "start:tunnel": "expo start --go --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "network:fix": "powershell -ExecutionPolicy Bypass -File ./scripts/ensure-expo-firewall.ps1",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "icons": "node generate-icons.js"
  },
  "dependencies": {
    "@expo-google-fonts/comfortaa": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~55.0.27",
    "expo-blur": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.36",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.15",
    "expo-linear-gradient": "~55.0.15",
    "expo-linking": "~55.0.16",
    "expo-local-authentication": "~55.0.15",
    "expo-notifications": "~55.0.24",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-splash-screen": "~55.0.22",
    "expo-sqlite": "~55.0.17",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.25",
    "lucide-react-native": "^1.8.0",
    "posthog-react-native": "^4.46.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@napi-rs/canvas": "^1.0.0",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
